# Bot token from @BotFather, format <bot_id>:<hash> e.g. 123456789:AAH-xxxxxxxx
# The bot must be an admin (with "Post Messages") of the target channel/group below.
TELEGRAM_BOT_TOKEN=

# Target. A channel chat id (e.g. -1004341050758) or a public @username.
TELEGRAM_TARGET_GROUP=@badminton_test_group

# Shared secret the cron job sends as a Bearer token. Use a long random value.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=

# Fallback message if no built-in survey template exists.
TELEGRAM_DEFAULT_MESSAGE=Fallback badminton survey message

# cron-job.org REST API key (from Console -> Settings -> API). Used to query jobs.
CRONJOB_API_TOKEN=

# YouForm API token, used to fetch the live survey submission count ({count}).
YOUFORM_API_TOKEN=

# Secret token for the /telegram/webhook endpoint. Telegram echoes it in the
# X-Telegram-Bot-Api-Secret-Token header; we reject calls without it. Generate
# with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable the welcome-on-join webhook entirely.
TELEGRAM_WEBHOOK_SECRET=

# Welcome message posted when a user joins the linked discussion group. {name}
# becomes a clickable mention. Optional — a sensible default is built in.
# TELEGRAM_WELCOME_MESSAGE=

# Seconds before the welcome message auto-deletes (the joiner still gets the
# notification). Default 60. Set to 0 to keep welcomes permanently.
# TELEGRAM_WELCOME_TTL_SECONDS=60
